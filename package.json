{
  "name": "@not-a-waffle/pkmjs",
  "version": "0.0.10",
  "description": "Read-only Pokemon Containers based on PKHeX.Core",
  "license": "GPL-3.0",
  "author": "LegoFigure11",
  "type": "module",
  "files": [
    "pkmjs.min.js",
    "pkmjs.min.js.map"
  ],
  "main": "index.js",
  "unpkg": "pkmjs.min.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/legofigure11/pkmjs.git"
  },
  "scripts": {
    "build": "esbuild index.js --bundle --minify --sourcemap --format=iife --global-name=pkmjs --target=chrome58,firefox57,safari11,edge16 --outfile=pkmjs.min.js",
    "local": "esbuild index.js --bundle --format=iife --global-name=pkmjs --target=chrome58,firefox57,safari11,edge16 --outfile=pkmjs.js",
    "patch": "npm version patch --no-git-tag-version",
    "publish": "npm publish --access public"
  },
  "devDependencies": {
    "esbuild": "0.28.0"
  }
}
